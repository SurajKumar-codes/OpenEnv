# ─── OpenEnv Data Cleaning — Environment Variables ───────────────────
# Copy this file to `.env` and fill in your credentials.
#
# MANDATORY variables for inference.py:

# The API endpoint for the LLM
API_BASE_URL=https://router.huggingface.co/v1

# The model identifier to use for inference
MODEL_NAME=Qwen/Qwen2.5-72B-Instruct

# Your Hugging Face / API key (NO default — must be set)
HF_TOKEN=

# Optional — if you use from_docker_image():
# LOCAL_IMAGE_NAME=openenv-data-cleaning
